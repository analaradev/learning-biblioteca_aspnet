@model Taller_ASP.NET_Core.Models.Book

<div class="book-detail-card">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3 class="mb-1">@Model.Title</h3>
            <h5 class="text-primary mb-2">
                <i class="bi bi-person-fill"></i> @Model.Author
            </h5>
            <small class="text-muted">
                <i class="bi bi-calendar3"></i> Agregado: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        <div class="btn-group" role="group">
            <a asp-action="Edit" asp-route-id="@Model.id" 
               class="btn btn-sm btn-outline-primary" 
               title="Editar libro">
                <i class="bi bi-pencil-square"></i> Editar
            </a>

            <form asp-action="DeleteConfirmed" asp-route-id="@Model.id" 
                  method="post" 
                  style="display:inline;"
                  onsubmit="return confirm('¿Estás seguro de que deseas eliminar este libro?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar libro">
                    <i class="bi bi-trash3"></i> Eliminar
                </button>
            </form>
        </div>
    </div>

    <hr />

    <div class="mb-3">
        <h6 class="text-muted">Estado:</h6>
        <span class="badge @(Model.IsRead ? "bg-success" : "bg-warning text-dark") fs-6">
            @if (Model.IsRead)
            {
                    <i class="bi bi-check-circle-fill"></i> @:Leído
            }
            else
            {
                    <i class="bi bi-book"></i> @:Pendiente de leer
            }
        </span>
    </div>

    @if (!string.IsNullOrEmpty(Model.ISBN))
    {
            <div class="mb-3">
                <h6 class="text-muted">ISBN:</h6>
                <p><strong>@Model.ISBN</strong></p>
            </div>
    }

    @if (!string.IsNullOrEmpty(Model.Publisher))
    {
            <div class="mb-3">
                <h6 class="text-muted">Editorial:</h6>
                <p>@Model.Publisher</p>
            </div>
    }

    @if (Model.Year.HasValue)
    {
            <div class="mb-3">
                <h6 class="text-muted">Año de Publicación:</h6>
                <p>@Model.Year</p>
            </div>
    }

    @if (!string.IsNullOrEmpty(Model.Genre))
    {
            <div class="mb-3">
                <h6 class="text-muted">Género:</h6>
                <span class="badge bg-info text-dark fs-6">@Model.Genre</span>
            </div>
    }

    @if (!string.IsNullOrEmpty(Model.Description))
    {
            <div class="mb-3">
                <h6 class="text-muted">Sinopsis:</h6>
                <p style="text-align: justify;">@Model.Description</p>
            </div>
    }

    @if (Model.CoverImage != null && Model.CoverImage.Length > 0)
    {
            <div class="mb-3">
                <h6 class="text-muted">Portada:</h6>
                <div class="text-center">
                    <img src="data:@Model.ImageContentType;base64,@Convert.ToBase64String(Model.CoverImage)" 
                         alt="@Model.Title" 
                         class="img-fluid rounded shadow-sm"
                         style="max-height: 500px; object-fit: contain;">
                </div>
            </div>
    }

    <div class="mt-4 pt-3 border-top">
        <small class="text-muted">
            <i class="bi bi-info-circle"></i> 
            ID: @Model.id | Orden: @Model.Order
        </small>
    </div>
</div>