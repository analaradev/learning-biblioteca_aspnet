@model Taller_ASP.NET_Core.Models.Book

<div class="book-card @(Model.IsRead ? "completed" : "")" data-book-id="@Model.id">

    <!-- Checkbox -->
    <div class="book-checkbox" onclick="event.stopPropagation();">
        <form asp-action="ToggleRead" asp-route-id="@Model.id" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="checkbox" 
            @(Model.IsRead ? "checked" : "")
                   onchange="this.form.submit();">
        </form>
    </div>

    <!-- Contenido -->
    <div class="book-content" onclick="loadBookDetail(@Model.id)">
        <h5 class="book-title mb-1">@Model.Title</h5>
        
        @if (!string.IsNullOrEmpty(Model.Author))
        {
                <p class="book-author text-primary mb-1">
                    <i class="bi bi-person-fill"></i> @Model.Author
                </p>
        }

        @if (!string.IsNullOrEmpty(Model.Genre))
        {
                <span class="badge bg-info text-dark">@Model.Genre</span>
        }

        <small class="text-muted d-block mt-1">
            <i class="bi bi-calendar3"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </small>
    </div>

    <!-- Indicador de portada -->
    @if (Model.CoverImage != null && Model.CoverImage.Length > 0)
    {
            <div class="book-image-indicator" onclick="loadBookDetail(@Model.id)">
                <i class="bi bi-image-fill text-primary"></i>
            </div>
    }

    <!-- Handle para arrastrar -->
    <div class="book-drag-handle">
        <i class="bi bi-grip-vertical"></i>
    </div>
</div>